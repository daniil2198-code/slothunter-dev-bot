# Telegram bot from @BotFather. Required.
TELEGRAM_BOT_TOKEN=

# The single Telegram user_id allowed to talk to this bot. Required.
# Find yours via @userinfobot. Anyone else gets a silent drop.
ALLOWED_USER_ID=

# Where Claude Code operates by default. The user can switch via /cd.
# Default: /opt/slot-hunter (the prod project we iterate on right now).
DEFAULT_WORKDIR=/opt/slot-hunter

# Claude model. Defaults to whatever Claude Code's CLI picks for your
# subscription tier. Set explicitly for deterministic behavior.
# Recommended: claude-opus-4-7 (best reasoning, 1M context window via
# the beta flag below). Drop to claude-sonnet-4-5 for faster cheaper runs.
MODEL=claude-opus-4-7

# Comma-separated beta flags forwarded to Claude Code. The 1M context
# window for Opus is gated behind ``context-1m-2025-08-07``. Remove
# this line if your subscription doesn't have access.
CLAUDE_BETAS=context-1m-2025-08-07

# Logging — DEBUG | INFO | WARNING. INFO recommended in prod.
LOG_LEVEL=INFO

# Daily digest — when (HH:MM in Europe/Minsk) the bot sends a morning
# summary: commits since yesterday, ROADMAP changes, prod health, errors.
# Empty / unset = no digest.
DIGEST_TIME=09:00

# Project root the digest summarizes. Default: /opt/slot-hunter.
DIGEST_REPO=/opt/slot-hunter

# Local URL the digest probes for prod health. Empty = skip the probe.
DIGEST_HEALTHZ=http://127.0.0.1:8000/healthz

# systemd units the digest greps for ERROR/WARN over the last 24h.
# Comma-separated. Empty = skip.
DIGEST_LOG_UNITS=slot-hunter-api,slot-hunter-worker,slot-hunter-bot
